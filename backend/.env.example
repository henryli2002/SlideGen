# =============================================
# LLM 提供商配置
# 支持: openai | gemini
# =============================================
LLM_PROVIDER=gemini

# ---- OpenAI / OpenAI 兼容接口（适用于 OpenAI、DeepSeek、Moonshot、通义千问等）----
# LLM_API_KEY=sk-xxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- Gemini（当前使用）----
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL=gemini-2.5-pro

# =============================================
# 图片搜索配置（Pexels API）
# 免费申请：https://www.pexels.com/api/
# =============================================
PEXELS_API_KEY=your_pexels_api_key_here

# =============================================
# 本地图片生成服务（可选，详见 instruction.md）
# =============================================
# LOCAL_IMAGE_MODEL_URL=http://localhost:8001

# =============================================
# 前端服务配置
# =============================================
# 此处端口号需要与前端启动的端口号一致
FRONTEND_PORT=5173
