{
  "presetId": "bullets_icon_list",
  "name": "图标要点列表",
  "description": "每条要点带图标，3~5 条，视觉清晰",
  "category": "bullets",
  "elements": [
    {
      "role": "accent_bar",
      "type": "shape",
      "shape": "rectangle",
      "x": 0, "y": 0, "w": 100, "h": 1.5,
      "fillColor": "{{accentColor}}",
      "zIndex": 0
    },
    {
      "role": "title",
      "type": "text",
      "x": 5, "y": 3, "w": 90, "h": 16,
      "content": "{{title}}",
      "fontSize": 32,
      "fontWeight": "bold",
      "color": "{{titleColor}}",
      "textAlign": "left",
      "verticalAlign": "middle",
      "zIndex": 1
    },
    {
      "role": "icon_1",
      "type": "icon",
      "x": 5, "y": 23, "w": 5, "h": 9,
      "icon": "{{bullet1_icon}}",
      "color": "{{accentColor}}",
      "zIndex": 1
    },
    {
      "role": "bullet_1",
      "type": "text",
      "x": 12, "y": 23, "w": 83, "h": 9,
      "content": "{{bullet1}}",
      "fontSize": 20,
      "fontWeight": "normal",
      "color": "{{bodyColor}}",
      "textAlign": "left",
      "verticalAlign": "middle",
      "zIndex": 1
    },
    {
      "role": "icon_2",
      "type": "icon",
      "x": 5, "y": 35, "w": 5, "h": 9,
